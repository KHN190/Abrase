type User = { name: String, age: Int }

fn label(u: User) -> String {
  "{u.name}:{u.age}"
}

fn count_down(n: Int) -> Int {
  if n <= 0 {
    0
  } else {
    n + count_down(n - 1)
  }
}

fn main() -> String {
  let u: User = User { name: "Alice", age: 30 };
  let total = count_down(4);
  let body = label(u);
  let inc = |x: Int| -> Int { x + 1 };
  let next = inc(total);
  "user=[{body}] total={total} next={next}"
}
