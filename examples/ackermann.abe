// Ackermann function — classic double-recursion stress test.
// ack(m, n) grows extremely fast; ack(3, n) = 2^(n+3) - 3.
//
// ack(3, 3) = 2^6 - 3 = 61

fn ack(m: Int, n: Int) -> Int {
  if m == 0 {
    n + 1
  } else {
    if n == 0 {
      ack(m - 1, 1)
    } else {
      ack(m - 1, ack(m, n - 1))
    }
  }
}

fn main() -> Int {
  ack(3, 3)
}
