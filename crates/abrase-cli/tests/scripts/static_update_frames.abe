// A host-driven cart shape: a static array built by a function call, read
// every frame from `update`. Drives the cross-frame MODULE-table rc path.
fn build_bh(mh: Int) -> Array<Int> {
    let mut a = [0; 8];
    let mut y = 0;
    while y < 8 { a[y] = y * mh; y = y + 1 };
    a
}

static BH: Array<Int> = build_bh(110)

pub fn update() -> Int {
    BH[3]
}

fn main() -> Int { 0 }
