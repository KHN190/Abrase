effect Counter { op tick() -> Unit }

fn fire_three() -> <Counter> Unit {
    Counter.tick();
    Counter.tick();
    Counter.tick();
}

fn main() -> Int {
    let mut n = 0;
    handle fire_three() {
        return _   => n,
        Counter.tick => {
            n = n + 1;
            resume(())
        }
    }
}
