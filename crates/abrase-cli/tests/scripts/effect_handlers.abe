effect gen { op yield(v: Int) -> Unit }
effect choose { op pick() -> Bool }

fn produce() -> <gen> Unit {
  gen.yield(10);
  gen.yield(20)
}

fn sum_yields() -> Int {
  handle produce() {
    return done   => 0,
    gen.yield v   => v + resume(())
  }
}

fn search() -> <choose> Int {
  let a = if choose.pick() { 1 } else { 2 };
  let b = if choose.pick() { 10 } else { 20 };
  a + b
}

fn count_match() -> Int {
  handle search() {
    return v     => if v == 11 { 1 } else { 0 },
    choose.pick  => resume(true) + resume(false)
  }
}

fn main() -> Int {
  sum_yields() + count_match()
}
