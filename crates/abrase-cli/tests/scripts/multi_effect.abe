// Handler frame persists across multiple suspensions.
// scale.apply doubles each input; transform sums two scaled values.
// 3*2 + 7*2 = 6 + 14 = 20

effect scale { op apply(x: Int) -> Int }

fn transform(a: Int, b: Int) -> <scale> Int {
  let x = scale.apply(a);
  let y = scale.apply(b);
  x + y
}

fn main() -> Int {
  handle transform(3, 7) {
    scale.apply x => resume(x * 2)
    return v      => v
  }
}
