// A static initialized by a function call with an argument: the call's arg
// staging in __module_init must not clobber the module-table handle register.
fn build_bh(mh: Int) -> Array<Int> {
    let mut a = [0; 8];
    let mut y = 0;
    while y < 8 { a[y] = y * mh; y = y + 1 };
    a
}

static BH: Array<Int> = build_bh(110)

fn main() -> Int {
    BH[3]
}
