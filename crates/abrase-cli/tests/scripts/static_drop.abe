// Reading a heap-typed `static` hands the cart a ref-counted observer, so
// dropping that copy must NOT free the table's cell. If it did, the second
// read would hit a stale handle / refcount-underflow trap.
fn build() -> Array<Int> { [10, 20, 30] }

static mut DATA: Array<Int> = build()

fn peek() -> Int {
    let d = DATA;   // Ld + rc_inc: owning copy
    d[1]            // 20; `d` dropped here (rc_dec of the copy)
}

fn main() -> Int {
    let _a = peek();   // read + drop
    let _b = peek();   // read + drop again — table must still be alive
    peek()             // 20
}
